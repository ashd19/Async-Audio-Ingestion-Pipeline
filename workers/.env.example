# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=audio.processing.exchange
NORMALIZATION_QUEUE=audio.normalization.queue
TRANSCRIPTION_QUEUE=audio.transcription.queue
NORMALIZED_ROUTING_KEY=audio.normalized
TRANSCRIBED_ROUTING_KEY=audio.transcribed

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=audio-files
MINIO_SECURE=false

# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=audiopipeline
DB_USER=postgres
DB_PASSWORD=postgres

# Worker Configuration
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=5
LOG_LEVEL=INFO
WHISPER_MODEL=base
