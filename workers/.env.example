# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=audio.processing.exchange
NORMALIZATION_QUEUE=audio.normalization.queue
TRANSCRIPTION_QUEUE=audio.transcription.queue
NORMALIZED_ROUTING_KEY=audio.normalized
TRANSCRIBED_ROUTING_KEY=audio.transcribed

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=audio-files
MINIO_SECURE=false

# PostgreSQL Configuration
DATABASE_URL=postgresql://neondb_owner:npg_kPuc2ETbYV9S@ep-fancy-block-aqlaaek9-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DB_HOST=localhost
DB_PORT=5432
DB_NAME=audiopipeline
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=

# Worker Configuration
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=5
LOG_LEVEL=INFO
WHISPER_MODEL=base
